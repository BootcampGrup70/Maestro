# Copy to .env and adjust as needed. Values here are the defaults used by app/config.py.

# SQLite database file (async, aiosqlite). Path is relative to the backend/ dir unless absolute.
MAESTRO_DATABASE_URL=sqlite+aiosqlite:///./maestro.db

# Ollama server the agents talk to.
MAESTRO_OLLAMA_HOST=http://localhost:11434

# Sandbox root for the shared filesystem tool. All read/write ops are confined here.
MAESTRO_WORKSPACE_DIR=./workspace

# Max number of agents allowed to run concurrently (README: 2 concurrent Ollama models).
MAESTRO_MAX_CONCURRENT_RUNS=2

# Comma-separated list of allowed CORS origins for the local frontend.
MAESTRO_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
